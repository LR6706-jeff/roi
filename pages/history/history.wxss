.container {
  padding: 30rpx;
  background-color: #F5F7FA;
  min-height: 100vh;
  box-sizing: border-box;
}

.action-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.count-text {
  font-size: 26rpx;
  color: #8b949e;
}

.clear-btn {
  font-size: 26rpx;
  color: #0969da;
  font-weight: 500;
}

.history-list {
  height: calc(100vh - 120rpx);
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  border: 1px solid rgba(0, 0, 0, 0.03);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.badge {
  font-size: 20rpx;
  font-weight: bold;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.badge-kol {
  background: #fff0f2;
  color: #ff4d6d;
}

.badge-shop {
  background: #eef7ff;
  color: #0969da;
}

.time {
  font-size: 24rpx;
  color: #8b949e;
}

.delete-icon {
  margin-left: auto;
  font-size: 36rpx;
  color: #d1d5db;
  line-height: 36rpx;
  padding: 0 10rpx;
}

.grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.label {
  font-size: 20rpx;
  color: #8b949e;
  margin-bottom: 4rpx;
}

.value {
  font-size: 24rpx;
  font-weight: 600;
  color: #24292f;
}

.highlight-roi {
  color: #0969da;
}

.highlight-profit.pos {
  color: #2da44e;
}

.highlight-profit.neg {
  color: #cf222e;
}

.card-footer {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1px solid #f0f1f2;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.diag-title {
  font-size: 22rpx;
  font-weight: bold;
  color: #0969da;
}

.diag-content {
  font-size: 22rpx;
  color: #57606a;
  line-height: 1.4;
}

/* 空状态样式 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 40rpx;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  margin-top: 80rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #24292f;
  margin-bottom: 12rpx;
}

.empty-subtitle {
  font-size: 24rpx;
  color: #8b949e;
  text-align: center;
}

/* 广告模拟布局，超高还原度 */
.ad-mock {
  position: relative;
  width: 100%;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
  border: 1px solid rgba(0, 0, 0, 0.02);
  box-sizing: border-box;
}

.ad-badge {
  position: absolute;
  left: 12rpx;
  top: 12rpx;
  background: rgba(0, 0, 0, 0.2);
  color: #ffffff;
  font-size: 16rpx;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
}

.ad-left {
  display: flex;
  gap: 20rpx;
  align-items: center;
  flex: 1;
}

.ad-icon {
  width: 90rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #ff8a00, #da1b60);
  border-radius: 8rpx;
}

.ad-icon-yellow {
  background: linear-gradient(135deg, #ffc107, #ff9800);
}

.ad-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex: 1;
}

.ad-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #24292f;
  line-height: 1.3;
}

.ad-sub-info {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.ad-author {
  font-size: 20rpx;
  color: #8B949E;
}

.ad-btn {
  background: #00c853;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  padding: 14rpx 28rpx;
  border-radius: 10rpx;
}

.ad-bottom {
  margin-top: 100rpx;
}
