.container {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.header {
  text-align: center;
  padding: 20rpx 0;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  background: linear-gradient(90deg, #1e3a8a, #0d9488);
  -webkit-background-clip: text;
  color: transparent;
  display: block;
}

.subtitle {
  font-size: 22rpx;
  color: #64748b;
  margin-top: 10rpx;
  display: block;
}

/* 实时计算看板 */
.dashboard-card {
  background: rgba(255, 255, 255, 0.75);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 10px 30px rgba(166, 179, 194, 0.15);
  border-radius: 24rpx;
  padding: 40rpx;
}

.indicator-grid {
  display: flex;
  justify-content: space-between;
}

.indicator-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.label {
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 12rpx;
}

.value {
  font-size: 56rpx;
  font-weight: 800;
  font-family: 'Outfit', 'Courier New', Courier, monospace;
}

.text-green {
  color: #0d9488;
  text-shadow: 0 0 10px rgba(13, 148, 136, 0.1);
}

.text-red {
  color: #e11d48;
  text-shadow: 0 0 10px rgba(225, 29, 72, 0.1);
}

.text-blue {
  color: #2563eb;
  text-shadow: 0 0 10px rgba(37, 99, 235, 0.1);
}

.profit-divider {
  height: 1px;
  background: rgba(0, 0, 0, 0.05);
  margin: 30rpx 0;
}

.profit-row {
  display: flex;
  justify-content: space-around;
}

.profit-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.sub-label {
  font-size: 22rpx;
  color: #64748b;
  margin-bottom: 8rpx;
}

.sub-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #0f172a;
}

/* AI智能诊断 */
.ai-box {
  background: linear-gradient(135deg, rgba(13, 148, 136, 0.04) 0%, rgba(37, 99, 235, 0.04) 100%);
  border: 1px solid rgba(13, 148, 136, 0.15);
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4px 20px rgba(13, 148, 136, 0.02);
}

.ai-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.ai-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #0f766e;
}

.ai-content {
  font-size: 26rpx;
  line-height: 1.6;
}

.ai-text {
  color: #334155;
  display: block;
}

.ai-placeholder {
  text-align: center;
  color: #64748b;
  padding: 20rpx 0;
}

.ai-btn {
  margin-top: 20rpx;
  background: linear-gradient(90deg, #0d9488, #2563eb);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: bold;
  border-radius: 30rpx;
  border: none;
  box-shadow: 0 4px 15px rgba(13, 148, 136, 0.15);
}

/* 浅色输入卡片 */
.form-card {
  background: rgba(255, 255, 255, 0.65);
  border: 1px solid rgba(255, 255, 255, 0.6);
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 5px 15px rgba(166, 179, 194, 0.03);
}

.form-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 24rpx;
  border-left: 6rpx solid #2563eb;
  padding-left: 15rpx;
}

.input-group {
  margin-bottom: 20rpx;
}

.input-group-row {
  display: flex;
  gap: 20rpx;
}

.input-group.half {
  flex: 1;
}

.input-label {
  font-size: 22rpx;
  color: #475569;
  margin-bottom: 10rpx;
  display: block;
}

input {
  background: #ffffff;
  border: 1px solid #cbd5e1;
  border-radius: 12rpx;
  height: 80rpx;
  padding: 0 24rpx;
  color: #0f172a;
  font-size: 28rpx;
  transition: all 0.3s ease;
}

input:focus {
  border-color: #2563eb;
  box-shadow: 0 0 10px rgba(37, 99, 235, 0.1);
}

.placeholder-style {
  color: #94a3b8;
}

/* 重置按钮 */
.action-bar {
  display: flex;
  justify-content: center;
  margin-top: 10rpx;
  margin-bottom: 40rpx;
}

.reset-btn {
  background: transparent;
  color: #64748b;
  border: 1px solid #cbd5e1;
  font-size: 24rpx;
  border-radius: 30rpx;
  padding: 10rpx 40rpx;
}

/* 顶部达人/商家切换样式 */
.tab-toggle {
  display: flex;
  background: #eef1f6;
  border-radius: 16rpx;
  padding: 6rpx;
  margin-bottom: 10rpx;
}

.toggle-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #8b949e;
  padding: 16rpx 0;
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.toggle-item.active {
  background: #ffffff;
  color: #0969da;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.05);
}
